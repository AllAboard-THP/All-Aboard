# URL interne pour le serveur Next uniquement (SSR, Server Actions, Route Handlers).
# En local : API sur 127.0.0.1:4000. Sur Dokploy : nom DNS interne du service API + port 4000.
# Ne pas utiliser de prefixe NEXT_PUBLIC_ (non expose au bundle client).
API_URL=http://127.0.0.1:4000

# Origine publique HTTPS de l'API pour le navigateur (useQuery client direct vers Fastify).
# Non requis si le client appelle uniquement un Route Handler Next (BFF), ex. GET /api/feed.
# Voir Docs/deploiement-dokploy-instance-allaboard.md
# NEXT_PUBLIC_API_URL=

# API Fastify
PORT=4000
HOST=0.0.0.0

# Postgres (API). Local : `docker compose up -d` puis URL ci-dessous. Dokploy : service interne + port 5432.
# DATABASE_URL=postgresql://allaboard:allaboard@127.0.0.1:5432/allaboard

# Auth API (ADR Docs/adr/0001-authentication-strategy.md)
# JWT_SECRET=change-me-in-dev
# Mot de passe partagé MVP pour POST /auth/login (corps { "userId", "password" }).
# MVP_LOGIN_PASSWORD=dev-only-password
# Identifiants recevant role mentor au login (CSV). Defaut API : alice
# MVP_MENTOR_USER_IDS=alice
