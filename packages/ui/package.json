    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@allaboard/config-eslint": "workspace:*",
    "@allaboard/config-typescript": "workspace:*",
    "@storybook/react": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
