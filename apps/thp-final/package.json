{
  "name": "thp-final",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/application.js app/javascript/react_mount.js --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.js=jsx --loader:.jsx=jsx --jsx=automatic",
    "build:watch": "esbuild app/javascript/application.js app/javascript/react_mount.js --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.js=jsx --loader:.jsx=jsx --jsx=automatic --watch",
    "dev": "bin/dev",
    "lint": "bundle exec rubocop",
    "test": "bundle exec rails test",
    "typecheck": "bundle exec rails zeitwerk:check"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@monaco-editor/react": "^4.7.0",
    "@rails/actioncable": "^8.1.300",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
