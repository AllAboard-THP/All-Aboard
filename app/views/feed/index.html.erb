<% content_for :title, "AllAboard" %>

<button id="scroll-top-btn"
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        class="fixed bottom-24 md:bottom-8 right-5 z-40 w-11 h-11 rounded-full bg-primary hover:bg-primary/80 text-white shadow-lg shadow-primary/30 flex items-center justify-center transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
        aria-label="Remonter en haut">
  <i class="fas fa-arrow-up text-sm"></i>
</button>

<script>
  (function() {
    var btn = document.getElementById('scroll-top-btn');
    if (!btn) return;
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        btn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        btn.classList.add('opacity-100', 'translate-y-0');
      } else {
        btn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        btn.classList.remove('opacity-100', 'translate-y-0');
      }
    }, { passive: true });
  })();
</script>

<div class="animate-fade-in">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
    <div class="hidden lg:block lg:col-span-3 space-y-6 sticky top-24">
      <%= render "feed/recently_viewed", recently_viewed: @recently_viewed %>

      <div class="glass rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <i class="fas fa-circle-question text-orange-400 text-sm"></i>
          <h3 class="font-semibold text-gray-300">Sans réponse</h3>
          <% if @unanswered_posts.any? %>
            <span class="ml-auto text-xs font-medium px-2 py-0.5 rounded-full bg-orange-500/20 text-orange-400">
              <%= @unanswered_posts.size %>
            </span>
          <% end %>
        </div>

        <% if @unanswered_posts.any? %>
          <div class="space-y-3">
            <% @unanswered_posts.each do |post| %>
              <%= link_to post_path(post), class: "block group", data: { turbo_frame: "_top" } do %>
                <div class="p-3 rounded-xl bg-white/5 hover:bg-white/8 transition-colors">
                  <div class="flex items-center gap-1.5 mb-1">
                    <% if post.subject %>
                      <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full"
                            style="color:<%= post.subject.accent_color %>;background-color:<%= post.subject.accent_color %>18;">
                        <%= post.subject.name %>
                      </span>
                    <% end %>
                    <% if post.urgent? %>
                      <span class="text-[10px] text-orange-400"><i class="fas fa-exclamation-circle"></i></span>
                    <% end %>
                    <span class="text-[10px] text-gray-500 ml-auto"><%= relative_time(post.created_at) %></span>
                  </div>
                  <p class="text-xs text-gray-300 line-clamp-2 group-hover:text-white transition-colors">
                    <%= post.title %>
                  </p>
                  <div class="flex items-center gap-1.5 mt-1.5">
                    <img src="<%= post.user.profile_avatar %>" class="w-4 h-4 rounded-full">
                    <span class="text-[10px] text-gray-500"><%= post.user.display_name %></span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4 text-gray-500">
            <i class="fas fa-check-circle text-emerald-400 text-2xl mb-2 block"></i>
            <p class="text-xs">Tous les posts ont au moins une réponse !</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="col-span-1 lg:col-span-6 space-y-6">
      <div data-react-component="FeedFilters"
           data-react-props="<%= {
             subjects:           @subjects.first(7).map { |s| { slug: s.slug, name: s.name, icon: s.icon, accent_color: s.accent_color } },
             currentSubjectSlug: @selected_subject&.slug,
             currentTag:         @selected_tag&.slug,
             feedPath:           authenticated_root_path
           }.to_json.html_safe %>">
      </div>

      <div class="glass rounded-2xl p-4 flex items-center gap-4">
        <img src="<%= current_user.profile_avatar %>" alt="<%= current_user.display_name %>" class="w-10 h-10 rounded-full">
        <button type="button" data-action="modal#open" class="flex-1 text-left bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-gray-400 hover:border-primary transition-colors">
          Demander de l'aide sur un sujet...
        </button>
        <button type="button" data-action="modal#open" class="p-3 rounded-xl bg-primary/20 text-primary hover:bg-primary/30 transition-colors">
          <i class="fas fa-paper-plane"></i>
        </button>
      </div>

      <div class="space-y-6">
        <% if @posts.any? %>
          <%= render @posts %>
          <% if @pagy.pages > 1 %>
            <div class="flex items-center justify-center gap-2 pt-2">
              <%== pagy_nav(@pagy) %>
            </div>
          <% end %>
        <% else %>
          <div class="glass rounded-2xl p-10 text-center text-gray-400">
            <i class="fas fa-sparkles text-4xl text-primary mb-4"></i>
            <p>Aucune requête ne correspond encore à ce filtre.</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="hidden lg:block lg:col-span-3 space-y-6 sticky top-24">
      <div class="glass rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <i class="fas fa-magnifying-glass text-primary text-sm"></i>
          <h3 class="font-semibold text-gray-300">Rechercher</h3>
        </div>
        <%= form_with url: feed_path, method: :get, data: { turbo: false } do |f| %>
          <div class="relative">
            <%= f.search_field :q,
                value: @search_query,
                placeholder: "Titre, contenu, tag…",
                class: "w-full bg-white/5 border border-white/10 rounded-xl pl-4 pr-10 py-3 text-sm focus:outline-none focus:border-primary transition-colors placeholder-gray-500",
                autocomplete: "off" %>
            <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-primary transition-colors">
              <i class="fas fa-arrow-right text-sm"></i>
            </button>
          </div>
          <% if @search_query.present? %>
            <div class="mt-3 flex items-center justify-between">
              <p class="text-xs text-gray-400">
                <span class="text-primary font-medium"><%= @posts.size %></span> résultat<%= "s" if @posts.size != 1 %> pour
                <span class="text-white/70 italic">"<%= @search_query %>"</span>
              </p>
              <%= link_to feed_path, class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" do %>
                <i class="fas fa-times mr-1"></i>Effacer
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="glass rounded-2xl p-6">
        <h3 class="font-semibold mb-4 text-gray-300 flex items-center gap-2">
          <i class="fas fa-comment-dots text-primary text-sm"></i>
          Dernières contributions
        </h3>
        <% if @recent_contributions.any? %>
          <div class="space-y-3">
            <% @recent_contributions.each do |comment| %>
              <%= link_to post_path(comment.post), class: "block group", data: { turbo_frame: "_top" } do %>
                <div class="p-3 rounded-xl bg-white/5 hover:bg-white/8 transition-colors">
                  <div class="flex items-center gap-1.5 mb-1">
                    <% if comment.post.subject %>
                      <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full"
                            style="color:<%= comment.post.subject.accent_color %>;background-color:<%= comment.post.subject.accent_color %>18;">
                        <%= comment.post.subject.name %>
                      </span>
                    <% end %>
                    <span class="text-[10px] text-gray-500 ml-auto"><%= relative_time(comment.created_at) %></span>
                  </div>
                  <p class="text-xs text-gray-400 line-clamp-1 group-hover:text-gray-300 transition-colors"><%= comment.post.title %></p>
                  <p class="text-xs text-gray-500 line-clamp-2 mt-0.5 italic">"<%= comment.body %>"</p>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4 text-gray-500">
            <i class="far fa-comment-dots text-2xl mb-2 block text-gray-600"></i>
            <p class="text-xs">Tes réponses apparaîtront ici.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
